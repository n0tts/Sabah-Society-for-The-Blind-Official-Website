---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import newsImage1 from '../assets/shbh-booth-exhibition.jpg';
import newsImage2 from '../assets/braille-machine-donation.jpg';
import newsImage3 from '../assets/certificate-presentation.jpg';
---

<BaseLayout 
	title="Media | Sabah Society for the Blind"
	image={newsImage1.src}
>
	<Header />

	<main>
		<!-- Hero Section -->
		<section class="bg-primary text-white py-20">
			<div class="container mx-auto px-4">
				<div class="max-w-3xl">
					<h1 class="text-4xl md:text-5xl font-heading font-bold mb-6">Media & Updates</h1>
					<p class="text-xl text-slate-200 leading-relaxed">
						Explore the latest news, community activities, campaigns, and stories that reflect the work of Sabah Society for the Blind across the state.
					</p>
				</div>
			</div>
		</section>

		<!-- Media Content -->
		<section class="py-20 bg-white">
			<div class="container mx-auto px-4">
				<p class="text-lg text-slate-700 leading-relaxed max-w-4xl mb-16">
					Stay informed with highlights from events, outreach efforts, partnerships, and fundraising campaigns that support the blind community in Sabah. This page shares milestones, public activities, and stories that show the impact of the organization’s work.
				</p>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<!-- News Card 1 -->
					<div class="group cursor-pointer">
						<div class="aspect-[4/3] rounded-2xl overflow-hidden mb-6 shadow-md transition-transform group-hover:scale-105">
							<Image src={newsImage1} alt="Community Activities and Outreach" class="w-full h-full object-cover" />
						</div>
						<h3 class="text-xl font-heading text-primary mb-2 group-hover:text-accent transition-colors uppercase">Community Activities and Outreach</h3>
						<p class="text-sm text-slate-500 mb-4 italic">Updated: March 2026</p>
						<p class="text-slate-600 line-clamp-3">Highlights from our recent outreach programs across various districts in Sabah, bringing services closer to those in need.</p>
					</div>

					<!-- News Card 2 -->
					<div class="group cursor-pointer">
						<div class="aspect-[4/3] rounded-2xl overflow-hidden mb-6 shadow-md transition-transform group-hover:scale-105">
							<Image src={newsImage2} alt="Public Appeals and Fundraising Campaigns" class="w-full h-full object-cover" />
						</div>
						<h3 class="text-xl font-heading text-primary mb-2 group-hover:text-accent transition-colors uppercase">Public Appeals and Fundraising</h3>
						<p class="text-sm text-slate-500 mb-4 italic">Updated: February 2026</p>
						<p class="text-slate-600 line-clamp-3">Our ongoing campaigns to secure equipment and resources for the training centers. Every contribution counts.</p>
					</div>

					<!-- News Card 3 -->
					<div class="group cursor-pointer">
						<div class="aspect-[4/3] rounded-2xl overflow-hidden mb-6 shadow-md transition-transform group-hover:scale-105">
							<Image src={newsImage3} alt="Stories From the Blind Community" class="w-full h-full object-cover" />
						</div>
						<h3 class="text-xl font-heading text-primary mb-2 group-hover:text-accent transition-colors uppercase">Stories From the Community</h3>
						<p class="text-sm text-slate-500 mb-4 italic">Updated: January 2026</p>
						<p class="text-slate-600 line-clamp-3">Personal stories of resilience and success from individuals who have benefited from our training and support programs.</p>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</BaseLayout>
