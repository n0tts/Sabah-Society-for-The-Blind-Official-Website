---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Contact Us | Sabah Society for the Blind">
	<Header />

	<main>
		<!-- Hero Section -->
		<section class="bg-primary text-white py-20">
			<div class="container mx-auto px-4">
				<div class="max-w-3xl">
					<h1 class="text-4xl md:text-5xl font-heading font-bold mb-6">Get in Touch</h1>
					<p class="text-xl text-slate-200 leading-relaxed">
						Reach out for general enquiries, support information, partnership opportunities, or ways to contribute to the mission of Sabah Society for the Blind.
					</p>
				</div>
			</div>
		</section>

		<!-- Contact Content -->
		<section class="py-20 bg-white">
			<div class="container mx-auto px-4">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-16">
					<!-- Contact Info -->
					<div>
						<h2 class="text-3xl font-heading text-primary mb-8 underline decoration-accent decoration-4 underline-offset-8">We’re Here to Help</h2>
						<p class="text-lg text-slate-700 leading-relaxed mb-12">
							Whether you need information, want to support the organization, or wish to partner with the team, this is the place to start. The team welcomes enquiries from families, donors, volunteers, and community partners across Sabah.
						</p>

						<div class="space-y-8">
							<div class="flex items-start space-x-4">
								<div class="p-3 bg-slate-100 rounded-lg text-primary">
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
								</div>
								<div>
									<h3 class="font-heading text-lg text-primary uppercase">Location</h3>
									<p class="text-slate-600">Pusat Wallace sheltered Workshop, <br />Tuaran, Jalan Kg Tagas Tuaran, <br />Malaysia, 89290</p>
								</div>
							</div>

							<div class="flex items-start space-x-4">
								<div class="p-3 bg-slate-100 rounded-lg text-primary">
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
								</div>
								<div>
									<h3 class="font-heading text-lg text-primary uppercase">Email Address</h3>
									<p class="text-slate-600">sabahblindsociety@gmail.com</p>
								</div>
							</div>

							<div class="flex items-start space-x-4">
								<div class="p-3 bg-slate-100 rounded-lg text-primary">
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
								</div>
								<div>
									<h3 class="font-heading text-lg text-primary uppercase">Phone Number</h3>
									<p class="text-slate-600">+60 88-788 543</p>
								</div>
							</div>

							<div class="flex items-start space-x-4">
								<div class="p-3 bg-slate-100 rounded-lg text-primary">
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-4.889 4.981L12 21.012a9.145 9.145 0 0 1-4.657-1.259L3 21l1.268-4.234a9.145 9.145 0 0 1-1.385-4.895C2.883 6.848 7.027 2.7 12.012 2.7c2.42 0 4.695.94 6.406 2.651a9.09 9.09 0 0 1 2.652 6.406c0 4.987-4.145 9.035-9.13 9.035z"></path></svg>
								</div>
								<div>
									<h3 class="font-heading text-lg text-primary uppercase">WhatsApp</h3>
									<p class="text-slate-600">+60 11-2187 2345</p>
								</div>
							</div>
						</div>
					</div>

					<!-- Contact Form -->
					<div class="bg-slate-50 p-8 md:p-12 rounded-3xl border border-slate-200">
						<h2 class="text-2xl font-heading text-primary mb-8 uppercase">Send us a message</h2>
						
						<div id="form-success" class="hidden mb-8 p-4 bg-accent/20 border border-accent rounded-xl text-primary font-bold">
							Thank you! Your message has been successfully sent. We will get back to you soon.
						</div>

						<form action="https://formsubmit.co/thesabahpages@gmail.com" method="POST" class="space-y-6">
							<!-- FormSubmit Configuration -->
							<input type="hidden" name="_next" value={Astro.site ? new URL("/contact?success=true", Astro.site).toString() : "https://sabahblindsociety.org/contact?success=true"}>
							<input type="text" name="_honey" style="display:none">
							<input type="hidden" name="_captcha" value="false">
							<input type="hidden" name="_template" value="table">

							<div>
								<label for="name" class="block text-sm font-bold uppercase text-slate-500 mb-2">Your Name</label>
								<input type="text" id="name" name="name" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-4 focus:ring-accent focus:outline-none transition-all" required>
							</div>
							<div>
								<label for="email" class="block text-sm font-bold uppercase text-slate-500 mb-2">Email Address</label>
								<input type="email" id="email" name="email" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-4 focus:ring-accent focus:outline-none transition-all" required>
							</div>
							<div>
								<label for="subject" class="block text-sm font-bold uppercase text-slate-500 mb-2">Subject</label>
								<select id="subject" name="_subject" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-4 focus:ring-accent focus:outline-none transition-all">
									<option>General Enquiry</option>
									<option>Donation Enquiry</option>
									<option>Volunteering</option>
									<option>Partnership</option>
								</select>
							</div>
							<div>
								<label for="message" class="block text-sm font-bold uppercase text-slate-500 mb-2">Message</label>
								<textarea id="message" name="message" rows="5" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-4 focus:ring-accent focus:outline-none transition-all" required></textarea>
							</div>
							<Button type="submit" variant="primary" class="w-full">Send Message</Button>
						</form>
					</div>
				</div>
			</div>
		</section>

		<!-- Map Section (Placeholder) -->
		<section class="h-96 w-full bg-slate-200 grayscale contrast-125">
			<div class="flex items-center justify-center h-full text-slate-400 font-heading uppercase tracking-widest">
				Map Section: Pusat Wallace, Tuaran
			</div>
		</section>
	</main>

	<Footer />

	<script>
		// Check for URL parameters
		const urlParams = new URLSearchParams(window.location.search);
		if (urlParams.get('success') === 'true') {
			const successMessage = document.getElementById('form-success');
			if (successMessage) {
				successMessage.classList.remove('hidden');
				// Clean up the URL
				window.history.replaceState({}, document.title, window.location.pathname);
			}
		}
	</script>
</BaseLayout>
