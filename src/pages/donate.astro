---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Donation | Sabah Society for the Blind">
	<Header />

	<main>
		<!-- Hero Section -->
		<section class="bg-primary text-white py-20">
			<div class="container mx-auto px-4">
				<div class="max-w-3xl">
					<h1 class="text-4xl md:text-5xl font-heading font-bold mb-6 uppercase tracking-tight">Support Our Work</h1>
					<p class="text-xl text-slate-200 leading-relaxed">
						Your donation helps sustain training, care, daily support, and essential services for blind and visually impaired individuals in Sabah.
					</p>
				</div>
			</div>
		</section>

		<!-- Donation Content -->
		<section class="py-20 bg-white">
			<div class="container mx-auto px-4">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
					<div>
						<h2 class="text-3xl font-heading text-primary mb-8 underline decoration-accent decoration-4 underline-offset-8">Give Hope, Give Opportunity</h2>
						<div class="space-y-6 text-lg text-slate-700 leading-relaxed">
							<p>
								Public support helps the organization continue providing practical assistance, training, and community care to those who need it most. 
							</p>
							<p>
								Every contribution strengthens the services and support that blind and visually impaired individuals rely on each day. Public reporting has shown that continuing training-centre operations requires substantial annual funding.
							</p>
							<p>
								Donations help close that gap and make it possible for Sabah Society for the Blind to continue serving those who rely on its programs and facilities.
							</p>
						</div>
						
						<div class="mt-12 bg-slate-50 p-8 rounded-3xl border border-slate-200">
							<h3 class="font-heading text-xl text-primary mb-4 uppercase">How to Donate</h3>
							<p class="text-slate-600 mb-6 italic">We currently accept Bank Transfers and Checks. Online payment integration is coming soon.</p>
							<div class="space-y-4">
								<div class="bg-white p-4 rounded-xl border border-slate-200">
									<p class="text-xs uppercase text-slate-400 font-bold mb-1">Bank Name</p>
									<p class="font-heading">Maybank (Malayan Banking Berhad)</p>
								</div>
								<div class="bg-white p-4 rounded-xl border border-slate-200">
									<p class="text-xs uppercase text-slate-400 font-bold mb-1">Account Name</p>
									<p class="font-heading">Sabah Society for the Blind</p>
								</div>
								<div class="bg-white p-4 rounded-xl border border-slate-200">
									<p class="text-xs uppercase text-slate-400 font-bold mb-1">Account Number</p>
									<p class="font-heading text-2xl tracking-wider text-primary">0100-1234-5678-9</p>
								</div>
							</div>
							<p class="mt-6 text-xs text-slate-500">Please send a copy of your transfer receipt to info@sabahblind.org for our records and tax-exempt receipt issuance.</p>
						</div>
					</div>
					
					<div class="space-y-8">
						<div class="bg-primary text-white p-8 rounded-3xl shadow-xl transform md:rotate-2">
							<h3 class="text-2xl font-heading mb-4 text-accent">Why Donate?</h3>
							<ul class="space-y-4">
								<li class="flex items-start space-x-3">
									<span class="text-accent text-xl">✓</span>
									<span>Supports daily operations of training centers.</span>
								</li>
								<li class="flex items-start space-x-3">
									<span class="text-accent text-xl">✓</span>
									<span>Provides welfare for visually impaired individuals.</span>
								</li>
								<li class="flex items-start space-x-3">
									<span class="text-accent text-xl">✓</span>
									<span>Funds essential equipment like Braille machines.</span>
								</li>
								<li class="flex items-start space-x-3">
									<span class="text-accent text-xl">✓</span>
									<span>Helps maintain branches in Tawau, Sandakan, and Keningau.</span>
								</li>
							</ul>
						</div>
						
						<div class="bg-accent p-8 rounded-3xl text-primary transform md:-rotate-1">
							<h3 class="text-2xl font-heading mb-4 uppercase">Other Ways to Help</h3>
							<div class="space-y-6">
								<div>
									<h4 class="font-bold mb-1">Partner With Us</h4>
									<p class="text-sm">Community groups and businesses can support through sponsorships and collaborative initiatives.</p>
								</div>
								<div>
									<h4 class="font-bold mb-1">Volunteer</h4>
									<p class="text-sm">Contribute time and skills to activities that strengthen the blind community.</p>
								</div>
							</div>
							<Button href="/contact" variant="primary" class="mt-8 w-full">Inquire About Volunteering</Button>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</BaseLayout>
